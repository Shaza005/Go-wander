<% layout("/layouts/boilerplate") %>

<body>
  <div class="container mt-4">
    <div class="row justify-content-center">

      <!-- FULL WIDTH ON MOBILE, CENTERED ON DESKTOP -->
      <div class="col-12 col-md-8 col-lg-6">

        <form method="POST"
              action="/listings"
              novalidate
              class="needs-validation"
              enctype="multipart/form-data">

          <h3 class="mb-3 text-center">Create a New Listing</h3>

          <!-- TITLE -->
          <div class="mb-3">
            <label class="form-label">Title</label>
            <input type="text"
                   class="form-control"
                   name="listing[title]"
                   placeholder="Enter title"
                   required>
            <div class="valid-feedback">Looks good</div>
            <div class="invalid-feedback">Title is required</div>
          </div>

          <!-- IMAGE -->
          <div class="mb-3">
            <label class="form-label">Upload Listing Image</label>
            <input type="file"
                   class="form-control"
                   name="listing[image]"
                   required>
          </div>

          <!-- DESCRIPTION -->
          <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea name="listing[description]"
                      class="form-control"
                      rows="4"
                      required></textarea>
            <div class="invalid-feedback">Please enter a description</div>
          </div>

          <!-- PRICE + LOCATION (STACKS ON MOBILE) -->
          <div class="row">
            <div class="col-12 col-md-4 mb-3">
              <label class="form-label">Price</label>
              <input name="listing[price]"
                     class="form-control"
                     placeholder="Enter price"
                     required>
            </div>

            <div class="col-12 col-md-8 mb-3">
              <label class="form-label">Location</label>
              <input type="text"
                     name="listing[location]"
                     class="form-control"
                     placeholder="Enter location"
                     required>
            </div>
          </div>

          <!-- COUNTRY -->
          <div class="mb-3">
            <label class="form-label">Country</label>
            <input type="text"
                   name="listing[country]"
                   class="form-control"
                   placeholder="Enter country"
                   required>
          </div>

          <!-- BUTTON -->
          <button class="btn btn-dark w-100 add-btn">
            Add Listing
          </button>

        </form>

      </div>
    </div>
  </div>
</body>