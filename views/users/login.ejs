<% layout("/layouts/boilerplate") %>

<style>

/* =========================
   BASE FIX (NO LOGIC CHANGE)
========================= */

.login-container{
    display:flex;
    justify-content:center;
}

/* =========================
   RESPONSIVENESS ONLY
========================= */

@media (max-width: 768px){

    h1.col-6.offset-3{
        width:100% !important;
        margin-left:0 !important;
        text-align:center;
    }

    .col-6.offset-3{
        width:100% !important;
        margin-left:0 !important;
        padding:0 1rem;
    }

    .form-control{
        font-size:1rem;
    }

    .btn{
        width:100%;
    }
}

@media (max-width: 480px){

    h1{
        font-size:1.5rem;
    }

    .form-control{
        font-size:0.95rem;
    }

    .mb-2{
        margin-bottom:1rem !important;
    }
}

</style>

<div class="row mt-3">

    <h1 class="col-6 offset-3">Login</h1>

    <div class="col-6 offset-3">

        <form action="/login"
              method="POST"
              class="needs-validation"
              novalidate>

            <div class="mb-2">
                <label for="username" class="form-label">Username</label>

                <input type="text"
                       id="username"
                       class="form-control"
                       name="username"
                       required />
            </div>

            <div class="mb-2">
                <label for="password" class="form-label">Password</label>

                <input type="password"
                       id="password"
                       class="form-control"
                       name="password"
                       required />
            </div>

            <button class="btn btn-dark add-btn w-100">
                Login
            </button>

        </form>

    </div>
</div>